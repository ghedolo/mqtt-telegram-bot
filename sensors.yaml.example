sensors:
  DEI-P2_T:
    topic: "esp32LRX/1/lora/dataRx/1/temperature"
    info: "DEI Piano 2 - Temp"
    unit: "°C"
    defaultAlarm: 30.0
    digest: true
    viewers: [cold_room_team]
    admins: [ops]

  DEI-P2_P:
    topic: "esp32LRX/1/lora/dataRx/1/pressure"
    info: "DEI Piano 2 - Press"
    unit: "hPa"
    viewers: [cold_room_team]
    admins: [ops]

  UG_T:
    topic: "esp32LRX/1/lora/dataRx/2/temperature"
    info: "Piano Terra - Temp"
    unit: "°C"
    defaultAlarm: 30.0
    digest: true
    viewers: [ground_floor_team]
    admins: [ops]

  UG_P:
    topic: "esp32LRX/1/lora/dataRx/2/pressure"
    info: "Piano Terra - Press"
    unit: "hPa"
    viewers: [ground_floor_team]
    admins: [ops]

  # Sensor with no viewers/admins — visible to nobody (fail-closed).
  # Uncomment and assign groups to grant access.
  # SECRET_SENSOR:
  #   topic: "internal/secret"
  #   viewers: []
  #   admins: []

defaults:
  interval: 300
  retention_days: 30
  alarm_threshold_repeat: 720
  alarm_offline_repeat: 3600
  debug: 0
