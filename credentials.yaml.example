telegram:
  token: "YOUR_BOT_TOKEN"          # from @BotFather
  group_id: -1000000000000         # Telegram group chat ID (negative integer), used for DM registration prompts
  poll_interval: 3                 # seconds, 1–10
  digest_time: "15:00"             # HH:MM daily digest (local time, TZ set in docker-compose)
  debug: 1                         # 0=critical only, 1=warnings+errors, 2=info, 3=verbose (debug)
  silent_start: 0                  # 1=suppress startup message in Telegram group
  enableMenu: 1                    # 1=register command autocomplete menu, 0=disable (handlers still work when typed)
  traceCmd: 0                      # 1=log every command (who ran what + outcome) to its own file; independent of debug
  traceCmdFile: "cmdtrace.log"     # where the command trace goes when traceCmd=1 (relative to the working dir)

# Superadmin — global list of chat_ids allowed to use /forgetSensor and /reloadConfig.
superadmin:
  - 123456789

# Access Groups — named sets of users referenced by sensors as viewers/admins.
# A user not listed in any group has no access to any sensor.
groups:
  ops:                             # can administer any sensor that lists this group as admins
    - 123456789
    - 987654321
  cold_room_team:                  # read-only access to cold room sensors
    - 111111111
    - 222222222
  ground_floor_team:               # read-only access to ground floor sensors
    - 333333333

mqtt:
  host: "mqtt.example.com"
  port: 8883                       # 8883 = TLS, 1883 = plain
  username: "your_username"
  password: "your_password"
